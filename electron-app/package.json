{
  "name": "project-manager-electron",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.config.mjs",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron . --no-sandbox",
    "start": "electron .",
    "build": "vite build --config vite.config.mjs",
    "typecheck": "tsc -p renderer/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
